@model Blog.Web.Areas.Admin.Models.SiteSettingUpdateViewModel
@{
    ViewData["Title"] = "Global Site Ayarları";
}

<div class="app-content-header">
    <div class="container-fluid">
        <h3 class="mb-0">Genel Ayarlar</h3>
    </div>
</div>

<div class="app-content">
    <div class="container-fluid">

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-1"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card card-primary card-outline">
            <form asp-action="Index" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />

                <div class="card-body">
                    <ul class="nav nav-tabs" id="settingTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="general-tab" data-bs-toggle="tab" data-bs-target="#general" type="button" role="tab">Genel</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="contact-tab" data-bs-toggle="tab" data-bs-target="#contact" type="button" role="tab">İletişim & Sosyal</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="advanced-tab" data-bs-toggle="tab" data-bs-target="#advanced" type="button" role="tab">Gelişmiş</button>
                        </li>
                    </ul>

                    <div class="tab-content pt-4" id="settingTabsContent">

                        <div class="tab-pane fade show active" id="general" role="tabpanel">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="SiteTitle" class="form-label">Site Başlığı (Title)</label>
                                    <input asp-for="SiteTitle" class="form-control" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="SiteDescription" class="form-label">Site Açıklaması (Meta Description)</label>
                                    <input asp-for="SiteDescription" class="form-control">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="LogoFile" class="form-label">Site Logosu</label>
                                    <input type="file" asp-for="LogoFile" class="form-control" accept="image/*">
                                    @if (!string.IsNullOrEmpty(Model.ExistingLogoPath))
                                    {
                                        <div class="mt-2"><img src="@Model.ExistingLogoPath" height="40" alt="Logo" /></div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="contact" role="tabpanel">
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label asp-for="ContactEmail" class="form-label">E-Posta Adresi</label>
                                    <input asp-for="ContactEmail" class="form-control">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="ContactPhone" class="form-label">Telefon Numarası</label>
                                    <input asp-for="ContactPhone" class="form-control">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="ContactAddress" class="form-label">Açık Adres</label>
                                    <input asp-for="ContactAddress" class="form-control">
                                </div>
                                <hr />
                                <div class="col-md-6 mb-3">
                                    <label asp-for="GithubUrl" class="form-label">GitHub URL</label>
                                    <input asp-for="GithubUrl" class="form-control">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="LinkedinUrl" class="form-label">LinkedIn URL</label>
                                    <input asp-for="LinkedinUrl" class="form-control">
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="advanced" role="tabpanel">
                            <div class="mb-3">
                                <label asp-for="GoogleAnalyticsCode" class="form-label">Google Analytics Kodu (Sadece Script etiketi arası)</label>
                                <textarea asp-for="GoogleAnalyticsCode" class="form-control" rows="4"></textarea>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-success"><i class="fas fa-save me-1"></i> Ayarları Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>