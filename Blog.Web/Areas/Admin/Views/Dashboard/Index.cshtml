@{
    ViewData["Title"] = "Kontrol Paneli";
}

<div class="app-content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h3 class="mb-0">Dashboard</h3>
            </div>
        </div>
    </div>
</div>

<div class="app-content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Sisteme Hoş Geldiniz</h3>
                    </div>
                    <div class="card-body">
                        Merhaba <b>@User.Identity!.Name</b>, yönetim paneline başarıyla giriş yaptın. Sol menüyü kullanarak işlemleri gerçekleştirebilirsin.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>