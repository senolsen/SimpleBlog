@model Blog.Web.Areas.Admin.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Admin Panel | Giriş Yap</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-beta2/dist/css/adminlte.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <style>
        /* Modern ve ferah bir degrade (gradient) arka plan */
        body.login-page {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Kartın daha geniş ve yumuşak hatlı olması */
        .login-box {
            width: 420px;
        }

        .modern-card {
            border-radius: 1rem;
            border: none;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        }

        .card-header {
            border-top-left-radius: 1rem !important;
            border-top-right-radius: 1rem !important;
            background-color: #fff;
            border-bottom: none;
            padding-top: 2rem;
        }

        .input-group-text {
            background-color: transparent;
            border-left: none;
            cursor: pointer;
        }

        .form-control {
            border-right: none;
        }

            .form-control:focus {
                box-shadow: none;
                border-color: #dee2e6;
            }

        .input-group:focus-within {
            box-shadow: 0 0 0 0.25rem rgba(102, 126, 234, 0.25);
            border-radius: 0.375rem;
        }
    </style>
</head>
<body class="login-page">

    <div class="login-box">
        <div class="card modern-card">
            <div class="card-header text-center">
                <a href="#" class="h1 text-decoration-none fw-bold text-dark">
                    <span class="text-primary">Blog</span>Admin
                </a>
            </div>

            <div class="card-body p-4">
                <p class="text-center text-muted mb-4">Yönetim paneline erişmek için giriş yapın</p>

                <form asp-action="Login" asp-controller="Auth" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger fw-bold text-center mb-3"></div>

                    <div class="mb-3">
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fas fa-envelope text-muted"></i></span>
                            <input asp-for="Email" class="form-control border-start-0 bg-light" placeholder="E-posta adresi" autocomplete="off">
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fas fa-lock text-muted"></i></span>
                            <input asp-for="Password" type="password" id="passwordInput" class="form-control border-start-0 bg-light" placeholder="Şifreniz" autocomplete="current-password">

                            <span class="input-group-text bg-light" id="togglePassword">
                                <i class="fas fa-eye text-muted" id="eyeIcon"></i>
                            </span>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="row align-items-center mb-3">
                        <div class="col-6">
                            <div class="form-check">
                                <input asp-for="RememberMe" class="form-check-input" type="checkbox" id="rememberMe">
                                <label asp-for="RememberMe" class="form-check-label text-muted" for="rememberMe">Beni Hatırla</label>
                            </div>
                        </div>
                        <div class="col-6 text-end">
                            <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold shadow-sm">Giriş Yap</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const togglePassword = document.getElementById('togglePassword');
            const passwordInput = document.getElementById('passwordInput');
            const eyeIcon = document.getElementById('eyeIcon');

            togglePassword.addEventListener('click', function () {
                // Şifre kutusunun type özelliğini kontrol et (password ise text yap, text ise password yap)
                const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                passwordInput.setAttribute('type', type);

                // İkonu değiştir (Açık göz / Kapalı göz)
                eyeIcon.classList.toggle('fa-eye');
                eyeIcon.classList.toggle('fa-eye-slash');

                // Tıklandığında input'a tekrar odaklan
                passwordInput.focus();
            });
        });
    </script>
</body>
</html>