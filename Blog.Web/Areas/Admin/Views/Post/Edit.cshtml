@model Blog.Web.Areas.Admin.Models.PostEditViewModel
@{
    ViewData["Title"] = "Yazı Düzenle";
}

<div class="app-content-header">
    <div class="container-fluid">
        <h3 class="mb-0">Yazı Düzenle</h3>
    </div>
</div>

<div class="app-content">
    <div class="container-fluid">
        <div class="card card-warning card-outline">
            <form asp-action="Edit" method="post" enctype="multipart/form-data" id="editForm">

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ExistingImagePath" />

                <div class="card-body">

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Başlık</label>
                        <input asp-for="Title" class="form-control" required>
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label">Kategori</label>
                        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select" required>
                            <option value="">Seçiniz...</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label d-block">Mevcut Kapak Fotoğrafı</label>
                        @if (!string.IsNullOrEmpty(Model.ExistingImagePath))
                        {
                            <img src="@Model.ExistingImagePath" alt="Kapak" class="img-thumbnail mb-2" style="max-height: 150px;" />
                        }
                        else
                        {
                            <span class="text-muted">Görsel bulunmamaktadır.</span>
                        }
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewCoverImageFile" class="form-label">Yeni Kapak Fotoğrafı Yükle (Değiştirmeyecekseniz boş bırakın)</label>
                        <input asp-for="NewCoverImageFile" type="file" class="form-control" accept="image/jpeg, image/png, image/webp">
                        <span asp-validation-for="NewCoverImageFile" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">İçerik</label>

                        <input type="hidden" asp-for="Content" id="hiddenContent">

                        <div id="quillEditor" style="height: 350px; background-color: #fff;">
                            @Html.Raw(Model.Content)
                        </div>
                        <span asp-validation-for="Content" class="text-danger"></span>
                    </div>
                    <hr class="my-4">
                    <h5 class="text-primary mb-3"><i class="fas fa-search"></i> SEO Ayarları</h5>

                    <div class="mb-3">
                        <label asp-for="MetaTitle" class="form-label">SEO Başlığı (Meta Title)</label>
                        <input asp-for="MetaTitle" class="form-control" placeholder="Örn: Yazılım Dersleri | Harika Blog" maxlength="70">
                        <small class="text-muted"><i class="fas fa-info-circle"></i> Boş bırakırsanız Google'da standart kategori adı görünür. Maks. 70 karakter.</small>
                        <span asp-validation-for="MetaTitle" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MetaDescription" class="form-label">SEO Açıklaması (Meta Description)</label>
                        <textarea asp-for="MetaDescription" class="form-control" rows="2" placeholder="Kategorinin arama motorlarında çıkacak kısa açıklamasını buraya yazın..." maxlength="160"></textarea>
                        <small class="text-muted"><i class="fas fa-info-circle"></i> Maksimum 160 karakter önerilir.</small>
                        <span asp-validation-for="MetaDescription" class="text-danger"></span>
                    </div>
                </div>

                <div class="card-footer">
                    <button type="submit" class="btn btn-warning">Değişiklikleri Kaydet</button>
                    <a asp-action="Index" class="btn btn-secondary">İptal</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>

    <script>
        // Quill Editörünü Başlatıyoruz
        var quill = new Quill('#quillEditor', {
            theme: 'snow',
            modules: {
                toolbar: [
                    [{ 'header': [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    ['blockquote', 'code-block'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    [{ 'color': [] }, { 'background': [] }],
                    ['link', 'clean']
                ]
            }
        });

        // Form gönderilirken (Submit) çalışacak olay
        var form = document.getElementById('editForm');
        form.onsubmit = function() {
            var hiddenContent = document.getElementById('hiddenContent');
            // Editörün içindeki HTML formatlı metni gizli input'a aktar
            hiddenContent.value = quill.root.innerHTML;
        };
    </script>
}