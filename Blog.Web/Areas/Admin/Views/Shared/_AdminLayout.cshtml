<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Blog Admin Yönetimi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-beta2/dist/css/adminlte.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
</head>
<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">
    <div class="app-wrapper">
        <nav class="app-header navbar navbar-expand bg-body">
            <div class="container-fluid">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button"><i class="fas fa-bars"></i></a>
                    </li>
                </ul>
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link text-danger" asp-area="Admin" asp-controller="Auth" asp-action="Logout">
                            <i class="fas fa-sign-out-alt"></i> Çıkış Yap
                        </a>
                    </li>
                </ul>
            </div>
        </nav>

        <aside class="app-sidebar bg-body-secondary shadow-sm" data-bs-theme="dark">
            <div class="sidebar-brand">
                <a href="#" class="brand-link">
                    <span class="brand-text fw-light">Blog Yönetim</span>
                </a>
            </div>
            <div class="sidebar-wrapper">
                <nav class="mt-2">
                    <ul class="nav sidebar-menu flex-column" data-lte-toggle="treeview" role="menu" data-accordion="false">
                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="nav-link">
                                <i class="nav-icon fas fa-tachometer-alt"></i>
                                <p>Dashboard</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="nav-link">
                                <i class="nav-icon fas fa-list"></i>
                                <p>Kategoriler</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="Post" asp-action="Index" class="nav-link">
                                <i class="nav-icon fas fa-edit"></i>
                                <p>Yazı Yönetimi</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="User" asp-action="Index" class="nav-link">
                                <i class="nav-icon fas fa-users"></i>
                                <p>Kullanıcı Yönetimi</p>
                            </a>
                        </li>
                       <li class="nav-item">
                            <a asp-area="Admin" asp-controller="SiteSetting" asp-action="Index" class="nav-link">
                                <i class="nav-icon fas fa-cog"></i>
                                <p>Genel Ayarlar</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="Auth" asp-action="Logout" class="nav-link">
                                <i class="nav-icon fas fa-sign-out-alt"></i>
                                <p>Çıkış Yap</p>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </aside>

        <main class="app-main">
            @RenderBody()
        </main>

        <footer class="app-footer">
            <div class="float-end d-none d-sm-inline">v1.0.0</div>
            <strong>Copyright &copy; @DateTime.Now.Year <a href="#">Blog Projesi</a>.</strong> Tüm hakları saklıdır.
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-beta2/dist/js/adminlte.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Sınıfı 'btn-delete' olan tüm butonları yakala
            const deleteButtons = document.querySelectorAll('.btn-delete');

            deleteButtons.forEach(button => {
                button.addEventListener('click', function (e) {
                    e.preventDefault(); // Butona basıldığında anında sayfaya gitmeyi durdur

                    const url = this.getAttribute('href');
                    const itemName = this.getAttribute('data-name') || 'Bu kayıt'; // data-name yoksa varsayılan metin

                    Swal.fire({
                        title: 'Emin misiniz?',
                        text: `${itemName} silinecek. Bu işlemi onaylıyor musunuz?`,
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#d33',
                        cancelButtonColor: '#3085d6',
                        confirmButtonText: 'Evet, Sil!',
                        cancelButtonText: 'İptal'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            // Kullanıcı onay verirse, yakaladığımız URL'ye yönlendir
                            window.location.href = url;
                        }
                    });
                });
            });
        });


    </script>

    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                Swal.fire({
                    position: 'top-end',
                    icon: 'success',
                    title: 'Başarılı!',
                    // Eski bozuk çıkan kod: text: '@Html.Raw(TempData["SuccessMessage"])',
                    // YENİ VE SORUNSUZ KOD:
                    text: @Html.Raw(Json.Serialize(TempData["SuccessMessage"])),
                    showConfirmButton: false,
                    timer: 2500,
                    toast: true
                });
            });
        </script>
    }
</body>
</html>