@model Blog.Web.Areas.Admin.Models.ContactUpdateViewModel
@{
    ViewData["Title"] = "İletişim Ayarları";
}

<div class="app-content-header">
    <div class="container-fluid">
        <h3 class="mb-0">İletişim ve Adres Ayarları</h3>
    </div>
</div>

<div class="app-content">
    <div class="container-fluid">
        <div class="card card-primary card-outline">
            <form asp-action="Index" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="card-body">
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle"></i> Bu sayfada girdiğiniz bilgiler, web sitenizin iletişim sayfasında ve alt bilgi (footer) kısmında ziyaretçilere gösterilecektir.
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Phone" class="form-label"></label>
                            <input asp-for="Phone" class="form-control" placeholder="Örn: +90 555 123 45 67">
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="Örn: info@siteadi.com">
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label"></label>
                        <textarea asp-for="Address" class="form-control" rows="3" placeholder="Açık adresinizi buraya yazabilirsiniz..."></textarea>
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MapIframeSrc" class="form-label"></label>
                        <textarea asp-for="MapIframeSrc" class="form-control" rows="3" placeholder="Sadece Google Haritalar 'src' içeriğini (URL) yapıştırın..."></textarea>
                        <small class="text-muted">Google Haritalar'dan "Haritayı Yerleştir" dediğinizde çıkan kodun içindeki <b>src="..."</b> kısmındaki linki kopyalayıp buraya yapıştırın.</small>
                        <span asp-validation-for="MapIframeSrc" class="text-danger"></span>
                    </div>
                </div>

                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Değişiklikleri Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>