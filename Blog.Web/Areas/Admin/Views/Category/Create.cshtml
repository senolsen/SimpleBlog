@model Category
@{
    ViewData["Title"] = "Yeni Kategori";
}
<div class="app-content-header">
    <div class="container-fluid">
        <h3 class="mb-0">Yeni Kategori Ekle</h3>
    </div>
</div>
<div class="app-content">
    <div class="container-fluid">
        <div class="card card-primary card-outline">
            <form asp-action="Create" method="post">
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Kategori Adı</label>
                        <input asp-for="Name" class="form-control" required>
                    </div>
                    <hr class="my-4">
                    <h5 class="text-primary mb-3"><i class="fas fa-search"></i> SEO Ayarları</h5>

                    <div class="mb-3">
                        <label asp-for="MetaTitle" class="form-label">SEO Başlığı (Meta Title)</label>
                        <input asp-for="MetaTitle" class="form-control" placeholder="Örn: Yazılım Dersleri | Harika Blog" maxlength="70">
                        <small class="text-muted"><i class="fas fa-info-circle"></i> Boş bırakırsanız Google'da standart kategori adı görünür. Maks. 70 karakter.</small>
                        <span asp-validation-for="MetaTitle" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MetaDescription" class="form-label">SEO Açıklaması (Meta Description)</label>
                        <textarea asp-for="MetaDescription" class="form-control" rows="2" placeholder="Kategorinin arama motorlarında çıkacak kısa açıklamasını buraya yazın..." maxlength="160"></textarea>
                        <small class="text-muted"><i class="fas fa-info-circle"></i> Maksimum 160 karakter önerilir.</small>
                        <span asp-validation-for="MetaDescription" class="text-danger"></span>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-success">Kaydet</button>
                    <a asp-action="Index" class="btn btn-secondary">İptal</a>
                </div>
            </form>
        </div>
    </div>
</div>